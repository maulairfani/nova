# Copy this file to .env and fill in real values. Never commit .env.

# --- MCN TV database ---
TV_DB_USER=nova_tv
TV_DB_PASSWORD=changeme
# Read-only role used by mcp-tv's SQL Analytics Tool at runtime (created by an Alembic migration, see mcp_servers/tv/alembic)
TV_DB_READONLY_PASSWORD=changeme

# --- Nova's own conversation-state database ---
NOVA_KB_DB_USER=nova_kb
NOVA_KB_DB_PASSWORD=changeme

# --- LLM + embeddings, both routed through OpenRouter (ADR-0015) ---
OPENROUTER_API_KEY=sk-or-changeme
OPENROUTER_LLM_MODEL=openai/gpt-5.4-nano
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
