# Copy this file to .env and fill in real values. Never commit .env.

# --- MCN TV database ---
TV_DB_USER=nova_tv
TV_DB_PASSWORD=changeme
# Read-only role used by mcp-tv's SQL Analytics Tool at runtime (created by an Alembic migration, see mcp_servers/tv/alembic)
TV_DB_READONLY_PASSWORD=changeme

# --- MCN+ database (streaming + shorts, merged business unit — ADR-0014) ---
PLUS_DB_USER=nova_plus
PLUS_DB_PASSWORD=changeme
PLUS_DB_READONLY_PASSWORD=changeme

# --- MCN News database ---
NEWS_DB_USER=nova_news
NEWS_DB_PASSWORD=changeme
NEWS_DB_READONLY_PASSWORD=changeme

# --- Nova's own conversation-state database ---
CORE_DB_USER=nova_core
CORE_DB_PASSWORD=changeme

# --- LLM + embeddings, both routed through OpenRouter (ADR-0015) ---
OPENROUTER_API_KEY=sk-or-changeme
OPENROUTER_LLM_MODEL=openai/gpt-5.4-nano
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Web search (Shared MCP Server, ADR-0010) ---
TAVILY_API_KEY=tvly-changeme

# --- Production deployment only (docker-compose.prod.yml, ADR-0019) ---
# GitHub username/org that owns the GHCR images (ghcr.io/<GHCR_OWNER>/nova-*)
GHCR_OWNER=changeme
# Image tag to deploy — a released version tag (e.g. v0.1.0), defaults to "latest"
TAG=latest
# Domains pointed (DNS A record) at this VM's IP — Caddy issues TLS certs for these automatically
DOMAIN_FRONTEND=nova.example.com
DOMAIN_API=api.nova.example.com
